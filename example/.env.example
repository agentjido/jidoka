# Live LLM settings for the Phoenix example app.
#
# Copy this file to `example/.env`, or put the same values in the package root
# `.env`.

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Required for the Research Agent web search tool.
BRAVE_SEARCH_API_KEY=

# Optional. Falls back to openai:gpt-4o-mini.
JIDOKA_DEFAULT_MODEL=openai:gpt-4o-mini
