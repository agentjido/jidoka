# Live LLM settings for the Phoenix example app.
#
# Copy this file to `example/.env`, or put the same values in the package root
# `.env`.

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Required for the Research Agent web search tool.
# Optional for Knowledge Agent prompts that ask for live web evidence.
BRAVE_SEARCH_API_KEY=

# Optional. Usually leave unset; the example prefers the local binary installed
# by `mix jido_browser.install agent_browser --if-missing`.
# JIDO_BROWSER_AGENT_BROWSER_BINARY_PATH=

# Optional. Falls back to openai:gpt-4o-mini.
JIDOKA_DEFAULT_MODEL=openai:gpt-4o-mini
