# Jidoka V2 Getting Started

```elixir
Mix.install(
  [
    {:jidoka, path: Path.expand("..", __DIR__)}
  ],
  consolidate_protocols: false
)
```

## Define A Jido Action

```elixir
defmodule NotebookLocalTime do
  use Jidoka.Action,
    name: "local_time",
    description: "Returns a deterministic local time for a city.",
    schema:
      Zoi.object(%{
        city: Zoi.string() |> Zoi.default("Chicago")
      })

  @impl true
  def run(params, _context) do
    city = Map.get(params, :city) || Map.get(params, "city") || "Chicago"
    {:ok, %{city: city, time: "09:30", timezone: "America/Chicago"}}
  end
end
```

## Define An Agent

```elixir
defmodule NotebookTimeAgent do
  use Jidoka.Agent

  agent :notebook_time_agent do
    model %{provider: :test, id: "notebook-model"}
    generation %{temperature: 0.0, max_tokens: 256}
    instructions "Call local_time when asked for the time."
  end

  tools do
    action NotebookLocalTime
  end
end
```

## Inspect The Compiled Spec

```elixir
spec = NotebookTimeAgent.spec()

%{
  id: spec.id,
  model: Jidoka.Config.model_ref(spec.model),
  generation: spec.generation.params,
  operations: Enum.map(spec.operations, & &1.name)
}
```

```elixir
Jidoka.inspect(NotebookTimeAgent)
```

```elixir
{:ok, preflight} = Jidoka.preflight(NotebookTimeAgent, "What time is it in Chicago?")
preflight.prompt.messages
```

## Run With A Deterministic Model

```elixir
fake_llm = fn _intent, journal ->
  llm_calls =
    Enum.count(journal.results, fn {_id, result} ->
      result.kind == :llm
    end)

  case llm_calls do
    0 ->
      {:ok, %{type: :operation, name: "local_time", arguments: %{"city" => "Chicago"}}}

    1 ->
      {:ok, %{type: :final, content: "Chicago time is 09:30."}}
  end
end

{:ok, result} =
  NotebookTimeAgent.run_turn("What time is it in Chicago?",
    llm: fake_llm
  )

result.content
```

## Trace And Eval

```elixir
{:ok, trace_sink} = Jidoka.Trace.Sink.InMemory.start_link()

:ok =
  Jidoka.Trace.record(result.events, {Jidoka.Trace.Sink.InMemory, pid: trace_sink},
    policy: Jidoka.Trace.Policy.new!(redact_keys: [], omit_keys: [])
  )

Jidoka.Trace.Sink.InMemory.list(trace_sink)
|> Enum.map(& &1.event)
```

```elixir
{:ok, eval_run} =
  Jidoka.Eval.run_case(
    [
      id: "notebook_time_eval",
      agent: NotebookTimeAgent.spec(),
      input: "What time is it in Chicago?",
      assertions: %{
        contains: "09:30",
        operation_called: :local_time
      }
    ],
    llm: fake_llm,
    operations: Jidoka.Runtime.JidoActions.operations([NotebookLocalTime])
  )

Jidoka.inspect(eval_run)
```

## Inspect The Journal

```elixir
result.journal.results
|> Map.values()
|> Enum.map(fn effect_result ->
  %{
    kind: effect_result.kind,
    status: effect_result.status,
    output: effect_result.output
  }
end)
```

## Structured Result

```elixir
defmodule NotebookProfileAgent do
  use Jidoka.Agent

  agent :notebook_profile_agent do
    model %{provider: :test, id: "notebook-model"}
    instructions "Return a short profile summary."

    result schema: Zoi.object(%{
             name: Zoi.string(),
             score: Zoi.integer() |> Zoi.gte(0)
           }),
           max_repairs: 1
  end
end
```

```elixir
profile_llm = fn _intent, _journal ->
  {:ok,
   %{
     type: :final,
     content: "Ada is ready.",
     result: %{"name" => "Ada", "score" => 10}
   }}
end

{:ok, profile_result} = NotebookProfileAgent.run_turn("Summarize Ada.", llm: profile_llm)
profile_result.value
```

## Hibernate And Resume

```elixir
{:hibernate, snapshot} =
  NotebookTimeAgent.run_turn("What time is it in Chicago?",
    llm: fake_llm,
    checkpoint: :after_prompt
  )

snapshot.cursor
```

```elixir
{:ok, resumed_result} = Jidoka.resume(snapshot, llm: fake_llm)
resumed_result.content
```

## Live Mode

After adding `OPENAI_API_KEY` or `ANTHROPIC_API_KEY` to `.env`, define an agent
with a real model:

```elixir
# defmodule LiveTimeAgent do
#   use Jidoka.Agent
#
#   agent :live_time_agent do
#     model "openai:gpt-4o-mini"
#     instructions "Call local_time when asked for the time."
#   end
#
#   tools do
#     action NotebookLocalTime
#   end
# end
#
# LiveTimeAgent.chat("What time is it in Chicago?")
```
